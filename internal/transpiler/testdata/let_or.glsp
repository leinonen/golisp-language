(ns main)

(defn parse-body [req any] -> any
  (let-or [body (get req "body")  "missing body"
           name (get body "name") "name required"
           age  (get body "age")  "age required"]
    {"name" name "age" age}))

(defn multi-level [x any y any] -> any
  (let-or [a x "no x"
           b y "no y"]
    (str a b)))

(defn main []
  (let [result (parse-body {"body" {"name" "Alice" "age" 30}})]
    (fmt/println result)))
