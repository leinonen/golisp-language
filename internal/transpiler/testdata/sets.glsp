(ns main)

(defn make-set [] -> any
  #{1 2 3})

(defn has-two [s any] -> bool
  (contains? s 2))

(defn add-four [s any] -> any
  (conj s 4))

(defn set-size [s any] -> int
  (count s))

(defn set-union [a any b any] -> any
  (union a b))

(defn set-diff [a any b any] -> any
  (difference a b))

(defn set-inter [a any b any] -> any
  (intersection a b))
