(ns main
  (:import [golisp/web]))

(defn bad-request [msg string] -> web/Response
  (web/json-response 400 {"error" msg}))

(defn not-found [msg string] -> web/Response
  (web/json-response 404 {"error" msg}))

(defn server-error [err error] -> web/Response
  (web/json-response 500 {"error" (.Error err)}))
