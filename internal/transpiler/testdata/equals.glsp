(ns main)

;; Cross-type = / not=: native Go == compares interface values by dynamic type,
;; so an int64 from arithmetic never equalled an int literal, and slices/maps
;; aren't comparable at all. These all route through _glispEquals for value
;; semantics. Concrete same-typed scalars keep native ==.
;; (+ n 1) boxes to int64 and the literal 3 is an int, yet they are value-equal;
;; (= 1 1.0) is true (consistent with < >); slices and maps compare by value.
(defn checks [n] -> string
  (fmt/sprintf "arith=%v num=%v vec=%v map=%v"
               (= (+ n 1) 3)
               (= 1 1.0)
               (= [1 2 3] [1 2 3])
               (not= {:a 1} {:a 2})))

(defn main [] -> void
  (fmt/println (checks 2)))
