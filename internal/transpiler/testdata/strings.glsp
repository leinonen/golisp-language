(defn shout [s string] -> string
  (upper-case s))

(defn whisper [s string] -> string
  (lower-case s))

(defn clean [s string] -> string
  (trim s))

(defn words [s string] -> []any
  (split s " "))

(defn sentence [parts []any] -> string
  (join parts " "))

(defn has-prefix? [s string prefix string] -> bool
  (starts-with? s prefix))

(defn redact [s string word string] -> string
  (replace s word "***"))

(defn middle [s string] -> string
  (subs s 1 4))
