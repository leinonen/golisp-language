(ns main)

;; numeric predicates
(defn check-numeric [] -> bool
  (and (even? 4) (odd? 3) (pos? 1) (neg? -1) (zero? 0)))

;; inc / dec
(defn count-up [n any] -> any
  (inc n))

(defn count-down [n any] -> any
  (dec n))

;; distinct
(defn dedup-nums [] -> []any
  (distinct [1 2 1 3 2 4]))

;; remove
(defn filter-evens [nums []any] -> []any
  (remove (fn [x] (even? x)) nums))

;; keep
(defn safe-parse [strs []any] -> []any
  (keep (fn [s] (if (starts-with? (string s) "x") nil s)) strs))

;; split-at
(defn split-list [coll []any] -> []any
  (split-at 2 coll))

;; split-with
(defn split-positives [nums []any] -> []any
  (split-with (fn [x] (pos? x)) nums))

;; interleave
(defn weave [] -> []any
  (interleave [1 2 3] ["a" "b" "c"]))

;; not-any?
(defn all-positive [nums []any] -> bool
  (not-any? (fn [x] (neg? x)) nums))

;; sort
(defn sorted-nums [nums []any] -> []any
  (sort nums))

;; min-key / max-key
(defn shortest [] -> any
  (min-key (fn [s] (count s)) "abc" "de" "f"))

(defn longest [] -> any
  (max-key (fn [s] (count s)) "abc" "de" "f"))

;; blank? / capitalize
(defn is-blank [s string] -> bool
  (blank? s))

(defn cap-word [s string] -> string
  (capitalize s))

;; map-vals / map-keys
(defn double-vals [m map[string]any] -> map[string]any
  (map-vals (fn [v] (* (int v) 2)) m))

(defn upper-keys [m map[string]any] -> map[string]any
  (map-keys (fn [k] (upper-case (string k))) m))

;; reduce-kv
(defn kv-pairs [m map[string]any] -> []any
  (reduce-kv (fn [acc k v] (conj acc [k v])) [] m))
