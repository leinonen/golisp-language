(defn valid-email? [s string] -> bool
  (re/match "^[^@]+@[^@]+\\.[^@]+$" s))

(defn first-number [s string] -> any
  (re/find "\\d+" s))

(defn all-words [s string] -> []any
  (re/find-all "\\w+" s))

(defn normalize-spaces [s string] -> string
  (re/replace "\\s+" s " "))

(defn csv-fields [s string] -> []any
  (re/split "," s))
