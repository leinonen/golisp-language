(ns main (:import [fmt]))

(defn double-stage [ch (chan any)] -> (chan any)
  (pipeline [x ch]
    (* x 2)))

(defn two-stage [ch (chan any)] -> (chan any)
  (pipeline [x ch]
    (* x 2)
    (str x "-done")))

(defn process-items [ch (chan any)]
  (fan-out 4 [item ch]
    (fmt/println item)))

(defn merge-channels [a (chan any) b (chan any) c (chan any)] -> (chan any)
  (fan-in a b c))
