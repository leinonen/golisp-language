(defn greet [users any id any] -> any
  (if-let [user (get users id)]
    (str "hello " (:name user))
    "unknown user"))

(defn display-name [users any id any] -> any
  (if-let [{name :name} (get users id)]
    name
    "anon"))

(defn maybe-name [users any id any] -> any
  (if-let [user (get users id)]
    (:name user)))
