(defn double-all [nums []any] -> []any
  (map (fn [x] (* (int x) 2)) nums))

(defn evens [nums []any] -> []any
  (filter (fn [x] (= (mod (int x) 2) 0)) nums))

(defn sum [nums []any] -> int
  (int (reduce (fn [acc x] (+ (int acc) (int x))) 0 nums)))

(defn first-three [coll []any] -> []any
  (take 3 coll))

(defn skip-two [coll []any] -> []any
  (drop 2 coll))

(defn reversed [coll []any] -> []any
  (reverse coll))

(defn one-to-five [] -> []any
  (range 1 6))
