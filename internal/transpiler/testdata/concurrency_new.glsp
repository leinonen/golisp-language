(ns main
  (:import [fmt]))

; go-val: goroutine returning a future channel
(defn ^(chan any) start-task [^int x]
  (go-val (* x x)))

; par: parallel fire-and-wait with WaitGroup
(defn run-parallel []
  (par
    (fmt/println "task a")
    (fmt/println "task b")
    (fmt/println "task c")))

; for-chan: range over channel until closed
(defn drain [^(chan string) ch]
  (for-chan [msg ch]
    (fmt/println msg)))

; recv-ok!: comma-ok receive to detect closed channel
(defn try-recv [^(chan int) ch]
  (let [[val ok] (recv-ok! ch)]
    (if ok
      val
      -1)))

; with-lock: mutex critical section
(defn safe-inc [^*sync/Mutex mu ^*int counter]
  (with-lock mu
    (fmt/println "locked")))

; select! with :timeout
(defn with-timeout [^(chan string) ch]
  (select!
    ([msg ch] msg)
    (:timeout 5000 "timed out")))
