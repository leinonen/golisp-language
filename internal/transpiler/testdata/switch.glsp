(ns main)

(defn describe [x int] -> string
  (switch x
    1 "one"
    2 "two"
    3 "three"
    :default "other"))

(defn grade [score int] -> string
  (let [label (switch (/ score 10)
                 9 "A"
                 8 "B"
                 7 "C"
                 6 "D"
                 :default "F")]
    label))

(defn process [cmd string] -> any
  (switch cmd
    "start" (do (fmt/println "starting") true)
    "stop"  (do (fmt/println "stopping") false)))
