(defn get-second [coll []any] -> any
  (second coll))

(defn get-last [coll []any] -> any
  (last coll))

(defn is-empty [coll []any] -> bool
  (empty? coll))

(defn safe-coll [coll []any] -> any
  (not-empty coll))

(defn nested-get [m map[string]any] -> any
  (get-in m ["a" "b"]))

(defn nested-set [m map[string]any v any] -> map[string]any
  (assoc-in m ["a" "b"] v))

(defn nested-inc [m map[string]any] -> map[string]any
  (update-in m ["a" "count"] (fn [n] (+ (int n) 1))))

(defn bump [m map[string]any] -> map[string]any
  (update m "count" (fn [n] (+ (int n) 1))))

(defn project [m map[string]any] -> map[string]any
  (select-keys m ["id" "name"]))

(defn rename [m map[string]any] -> map[string]any
  (rename-keys m {"old-key" "new-key"}))

(defn group [users []any] -> map[string]any
  (group-by "status" users))

(defn freq [items []any] -> map[string]any
  (frequencies items))

(defn build-map [pairs []any] -> any
  (into {} pairs))

(defn join-seqs [a []any b []any c []any] -> []any
  (concat a b c))

(defn flat-map [coll []any] -> []any
  (mapcat (fn [x] [x x]) coll))

(defn take-pos [nums []any] -> []any
  (take-while (fn [n] (> (int n) 0)) nums))

(defn drop-neg [nums []any] -> []any
  (drop-while (fn [n] (< (int n) 0)) nums))

(defn zip [ks []any vs []any] -> map[string]any
  (zipmap ks vs))

(defn chunks [coll []any] -> []any
  (partition 3 coll))

(defn by-sign [nums []any] -> []any
  (partition-by (fn [n] (> (int n) 0)) nums))
