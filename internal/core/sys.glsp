;;; glisp core — the sys/ namespace: process & environment access.
;;; Glisp-native names over Go's os, so code says (sys/env "X") not (os/env "X").

(ns sys)

(defn args [] -> []string
  os/args)

;;; Returns the environment variable, or the optional fallback when unset/empty.
(defn env [name string & fallback] -> string
  (let [v (os/getenv name)]
    (if (and (= v "") (not (empty? fallback)))
      (str (first fallback))
      v)))

(defn exit [code int] -> void
  (os/exit code))
