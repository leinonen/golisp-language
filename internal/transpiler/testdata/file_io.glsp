(defn load-config [path string] -> [string error]
  (read-file path))

(defn save-result [path string content string] -> error
  (write-file path content))

(defn log-append [path string line string] -> error
  (append-file path line))

(defn config-exists? [path string] -> bool
  (file-exists? path))

(defn list-migrations [dir string] -> [[]any error]
  (list-dir dir))

(defn ensure-dir [path string] -> error
  (mkdir path))
