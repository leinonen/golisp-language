(ns main)

(defn main [] -> void
  (println (greet "World"))
  (println (greet "glisp"))
  (let [nums (map (fn [n] (square (int n))) (range 1 6))]
    (print-results "squares" nums))
  ;; Point is declared in helpers.glsp — field access and the Distance method
  ;; resolve across files.
  (let [p (Point. {:x 3.0 :y 4.0})]
    (fmt/printf "point (%v, %v) is %v from origin\n" (:x p) (:y p) (distance p))))
