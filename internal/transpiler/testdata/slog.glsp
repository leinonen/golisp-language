(defn log-request [method string path string status int]
  (log/info "request" "method" method "path" path "status" status))

(defn log-startup [port int]
  (log/info "server started" "port" port))

(defn log-slow [query string ms int]
  (log/warn "slow query" "sql" query "ms" ms))

(defn log-failure [op string err any]
  (log/error "operation failed" "op" op "err" err))

(defn log-trace [msg string]
  (log/debug msg))
