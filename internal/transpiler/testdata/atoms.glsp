(ns main)

(defn make-counter [] -> any
  (atom 0))

(defn increment [a any] -> any
  (swap! a (fn [x any] (+ x 1))))

(defn add-n [a any n any] -> any
  (swap! a (fn [x any] (+ x n))))

(defn set-value [a any v any] -> any
  (reset! a v))

(defn read-value [a any] -> any
  (deref a))

(defn counter-demo [] -> any
  (let [c (atom 0)]
    (swap! c (fn [x any] (+ x 1)))
    (swap! c (fn [x any] (+ x 1)))
    (reset! c 10)
    (deref c)))
