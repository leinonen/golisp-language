(ns main)

; go-val: goroutine returning a future channel
(defn start-task [x int] -> (chan any)
  (go-val (* x x)))

; par: parallel fire-and-wait with WaitGroup
(defn run-parallel []
  (par
    (fmt/println "task a")
    (fmt/println "task b")
    (fmt/println "task c")))

; for-chan: range over channel until closed
(defn drain [ch (chan string)]
  (for-chan [msg ch]
    (fmt/println msg)))

; recv-ok!: comma-ok receive to detect closed channel
(defn try-recv [ch (chan int)]
  (let [[val ok] (recv-ok! ch)]
    (if ok
      val
      -1)))

; with-lock: mutex critical section
(defn safe-inc [mu *sync/Mutex counter *int]
  (with-lock mu
    (fmt/println "locked")))

; select! with :timeout
(defn with-timeout [ch (chan string)]
  (select!
    ([msg ch] msg)
    (:timeout 5000 "timed out")))
