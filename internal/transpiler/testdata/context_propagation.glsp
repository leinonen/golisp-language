(ns main)

(defn background-ctx [] -> any
  (ctx/background))

(defn todo-ctx [] -> any
  (ctx/todo))

(defn with-cancel-example [] -> any
  (let [[ctx cancel] (ctx/with-cancel (ctx/background))]
    (ctx/cancel! cancel)
    ctx))

(defn with-timeout-example [] -> any
  (let [[ctx cancel] (ctx/with-timeout (ctx/background) 5000)]
    (ctx/cancel! cancel)
    ctx))

(defn store-value [ctx any key string val string] -> any
  (ctx/with-value ctx key val))

(defn read-value [ctx any key string] -> any
  (ctx/value ctx key))
